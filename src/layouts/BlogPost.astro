---
// @ts-nocheck
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, showHeroImage = false } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}

			.hero-image {
				display: flex;
				justify-content: center;
				padding: 2rem 1rem 1rem;
			}

			.hero-image img {
				width: 100%;
				max-width: 1100px;
				height: 460px;
				object-fit: cover;
				display: block;
				border: 1px solid #222;
			}

			.post-shell {
				width: min(1400px, calc(100% - 2rem));
				margin: 0 auto;
			}

			.post-header {
				width: min(780px, 100%);
				margin: 0 auto;
				padding: 1em 0;
				color: rgb(var(--gray-dark));
			}

			.post-content {
				width: 100%;
				padding: 0 0 2rem;
				color: rgb(var(--gray-dark));
			}

			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}

			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: 2.4em;
			}

			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				text-align: center;
			}

			.last-updated-on {
				font-style: italic;
			}

			:global(.gallery-masonry) {
				column-count: 4;
				column-gap: 14px;
				margin: 2rem 0;
			}

			:global(.gallery-masonry a) {
				display: block;
				margin-bottom: 14px;
				break-inside: avoid;
				-webkit-column-break-inside: avoid;
				page-break-inside: avoid;
				overflow: hidden;
				border-radius: 12px;
				text-decoration: none;
			}

			:global(.gallery-masonry img) {
				width: 100%;
				height: auto;
				display: block;
				border-radius: 12px;
				transition: transform 220ms ease, filter 220ms ease;
				will-change: transform;
			}

			:global(.gallery-masonry a:hover img) {
				transform: scale(1.03);
				filter: brightness(1.03) contrast(1.03);
			}

			:global(.gallery-masonry a:focus-visible img) {
				transform: scale(1.03);
				outline: 2px solid rgba(255, 60, 60, 0.7);
				outline-offset: 4px;
			}

			:global(.post-text) {
				width: min(780px, 100%);
				margin: 0 auto;
			}

			@media (prefers-reduced-motion: reduce) {
				:global(.gallery-masonry img) {
					transition: none;
				}
			}

			.lightbox {
				display: none;
				position: fixed;
				inset: 0;
				z-index: 2147483647;
				background: rgba(0, 0, 0, 0.95);
				justify-content: center;
				align-items: center;
				pointer-events: auto;
			}

			.lightbox.active {
				display: flex;
			}

			.lightbox img {
				max-width: min(1100px, 92vw);
				max-height: 92vh;
				object-fit: contain;
				border: none;
				border-radius: 0;
			}

			.lightbox-close {
				position: fixed;
				top: 18px;
				right: 22px;
				color: #fff;
				font-size: 40px;
				font-weight: 700;
				cursor: pointer;
				background: none;
				border: none;
				padding: 0;
				line-height: 1;
				z-index: 2147483647;
			}

			.lightbox-close:hover {
				color: #ff3c3c;
			}

			@media (max-width: 1100px) {
				:global(.gallery-masonry) {
					column-count: 3;
				}
			}

			@media (max-width: 900px) {
				:global(.gallery-masonry) {
					column-count: 2;
				}
			}

			@media (max-width: 600px) {
				:global(.gallery-masonry) {
					column-count: 1;
				}

				.hero-image img {
					height: 300px;
				}

				.post-shell {
					width: calc(100% - 1rem);
				}

				.title h1 {
					font-size: 1.9em;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<div id="lightbox" class="lightbox" aria-hidden="true">
			<button class="lightbox-close" type="button" aria-label="Close">&times;</button>
			<img id="lightbox-img" src="" alt="" />
		</div>

		<main>
			<article>
				{showHeroImage && heroImage && (
					<div class="hero-image">
						<img
							src={typeof heroImage === 'string' ? heroImage : heroImage.src}
							alt={title}
						/>
					</div>
				)}

				<div class="post-shell">
					<div class="post-header">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Last updated on <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
							<hr />
						</div>
					</div>

					<div class="post-content">
						<slot />
					</div>
				</div>
			</article>
		</main>

		<Footer />

		<script is:inline>
			const lightbox = document.getElementById('lightbox');
			const lightboxImg = document.getElementById('lightbox-img');
			const closeBtn = lightbox.querySelector('.lightbox-close');

			function openLightbox(src) {
				lightboxImg.src = src;
				lightbox.classList.add('active');
				lightbox.setAttribute('aria-hidden', 'false');
				document.documentElement.style.overflow = 'hidden';
			}

			function closeLightbox() {
				lightbox.classList.remove('active');
				lightbox.setAttribute('aria-hidden', 'true');
				lightboxImg.src = '';
				document.documentElement.style.overflow = '';
			}

			document.addEventListener('click', (e) => {
				const link = e.target.closest('.gallery a, .gallery-masonry a');
				if (link) {
					e.preventDefault();
					openLightbox(link.getAttribute('href'));
				}
			});

			closeBtn.addEventListener('click', closeLightbox);

			lightbox.addEventListener('click', (e) => {
				if (e.target === lightbox) closeLightbox();
			});

			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') closeLightbox();
			});
		</script>
	</body>
</html>