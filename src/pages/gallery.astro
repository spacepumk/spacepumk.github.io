  <style>
main {
  width: 100%;
  max-width: none;
  margin: 0;
  padding: 2em 2rem;
  box-sizing: border-box;
}

    h1 {
      text-align: center;
      margin-bottom: 0.5em;
    }

    .intro {
      text-align: center;
      color: #999;
      margin-bottom: 2em;
    }

.gallery-masonry {
  width: 100%;
  column-count: 5;
  column-gap: 1rem;
}

    .gallery-masonry a {
      display: inline-block;
      width: 100%;
      margin-bottom: 1rem;
      break-inside: avoid;
    }

    .gallery-masonry img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 8px;
    }

    @media (max-width: 1100px) {
      .gallery-masonry {
        column-count: 3;
      }
    }

    @media (max-width: 768px) {
      .gallery-masonry {
        column-count: 2;
      }
    }

    @media (max-width: 520px) {
      .gallery-masonry {
        column-count: 1;
      }
    }
  </style>
