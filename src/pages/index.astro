---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const featuredImages = [
  '/images/5sos-amsterdam-2026/michael-5.jpg',
  '/images/5sos-paris-2026/IMG_0838-Edit.png',
  '/images/5sos-amsterdam-2026/tt-5.jpg',
];
---

<!doctype html>
<html lang="en">
<head>
<BaseHead title={SITE_TITLE} description="Paris concert photography" />
</head>
<body>
<Header />

<!-- Image banner at top - OUTSIDE main -->
<section class="image-banner">
  {featuredImages.map((img) => (
    <img src={img} alt="Concert photo" />
  ))}
</section>

<main>
  <!-- Main intro -->
  <section class="intro">
    <h1>spacepumk</h1>
    <p class="tagline">paris and more concert photography.<br/></p>
  </section>

  <!-- What I do -->
  <section class="info">
    <p>I go to shows anyway. Might as well document it.</p>
    
    <p>Looking for a photographer for your show? Hit me up!</p>
  </section>


<section class="gallery-tape-wrap">
  <a href="/gallery" class="gallery-tape" aria-label="Open all photos gallery">
    <div class="gallery-tape-track">
      <span>ALL PHOTOS</span>
      <span>✦</span>
      <span>ENTER GALLERY</span>
      <span>✦</span>
      <span>ALL PHOTOS</span>
      <span>✦</span>
      <span>ENTER GALLERY</span>
      <span>✦</span>
      <span>ALL PHOTOS</span>
      <span>✦</span>
      <span>ENTER GALLERY</span>
      <span>✦</span>
      <span>ALL PHOTOS</span>
      <span>✦</span>
      <span>ENTER GALLERY</span>
    </div>
  </a>
</section>

<!-- CTA -->
<section class="cta">
  <a href="/blog" class="big-link">→ See all shows</a>
  <div class="show-links">
    <a href="/blog/waterparks-paris26">Waterparks Paris 2026</a>
    <a href="/blog/5sos-paris-26">5 Seconds of Summer Paris 2026</a>
    <a href="/blog/5sos-amsterdam-26">5 Seconds of Summer Amsterdam 2026</a>
  </div>
</section>


</main>

<Footer />
</body>
</html>









<style>
  /* Image banner */
  .image-banner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    margin: 0;
    padding: 0;
    width: 100%;
  }

  .image-banner img {
    width: 100%;
    height: 450px;
    object-fit: cover;
    display: block;
    margin: 0;
    padding: 0;
  }

  /* Main */
  main {
    max-width: 1000px;
    margin: 0 auto;
    padding-top: 3em;
  }

  section {
    padding: 0 2em;
  }

  .intro {
    text-align: center;
    margin-bottom: 3em;
  }

  .intro h1 {
    font-size: 3.5em;
    margin-bottom: 0.3em;
  }

  .tagline {
    font-size: 1.3em;
    line-height: 1.6;
    color: #ccc;
  }

  .info {
    max-width: 700px;
    margin: 0 auto 3em;
    line-height: 1.8;
  }

  .info p {
    margin-bottom: 1.5em;
  }

  .note {
    text-align: center;
    color: #999;
    margin-bottom: 2.5em;
  }

  .note p {
    margin: 0;
  }

  .recent-bands {
    background: #111;
    border-left: 3px solid #ff3c3c;
    padding: 1.5em;
    margin: 2em 0;
  }

  .recent-bands strong {
    color: #ff3c3c;
  }

  /* Gallery promo */
.gallery-tape-wrap {
  padding: 0 2em;
  margin: 2.5em 0 3em;
}

.gallery-tape {
  position: relative;
  display: block;
  overflow: hidden;
  border-top: 1px solid rgba(255, 60, 60, 0.35);
  border-bottom: 1px solid rgba(255, 60, 60, 0.35);
  background:
    linear-gradient(90deg, rgba(255, 60, 60, 0.12), rgba(255, 60, 60, 0.04) 30%, rgba(120, 0, 255, 0.08) 70%, rgba(255, 60, 60, 0.12)),
    #0a0a0a;
  text-decoration: none;
  white-space: nowrap;
  transform: rotate(-1.2deg);
  box-shadow: 0 0 24px rgba(255, 60, 60, 0.08);
}

.gallery-tape:hover {
  text-decoration: none;
  border-top-color: #ff3c3c;
  border-bottom-color: #ff3c3c;
  box-shadow: 0 0 30px rgba(255, 60, 60, 0.16);
}

.gallery-tape-track {
  display: inline-flex;
  align-items: center;
  gap: 1.5rem;
  padding: 0.95rem 0;
  min-width: max-content;
  animation: galleryTapeScroll 18s linear infinite;
  color: #ff4a4a;
  font-size: clamp(1rem, 2.4vw, 1.4rem);
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.gallery-tape:hover .gallery-tape-track {
  animation-play-state: paused;
}

.gallery-tape-track span {
  display: inline-block;
}

@keyframes galleryTapeScroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-25%);
  }
}

@media (max-width: 768px) {
  .gallery-tape-wrap {
    padding: 0 1em;
  }

  .gallery-tape {
    transform: rotate(-1deg);
  }

  .gallery-tape-track {
    gap: 1rem;
    padding: 0.8rem 0;
    font-size: 1rem;
  }
}

  /* CTA */
  .cta {
    text-align: center;
    margin: 4em 0;
    justify-content: center;
    align-items: center;
    gap: 2em;
  }

  .big-link {
    font-size: 1.5em;
    color: #ff3c3c;
    text-decoration: none;
    font-weight: bold;
  }

  .big-link:hover {
    text-decoration: underline;
  }

  .show-links {
    margin-top: 1.25em;
    display: flex;
    flex-direction: column;
    gap: 0.8em;
  }

  .show-links a {
    color: #ccc;
    text-decoration: none;
  }

  .show-links a:hover {
    color: #ff3c3c;
    text-decoration: underline;
  }

  .secondary-link {
    color: #999;
    text-decoration: none;
  }

  .secondary-link:hover {
    color: #ff3c3c;
  }

  .contact {
    text-align: center;
    padding: 3em 2em;
    border-top: 1px solid #222;
    color: #999;
  }

  .contact p {
    margin-bottom: 0.5em;
  }

  .contact a {
    color: #ff3c3c;
    text-decoration: none;
  }

  .contact a:hover {
    text-decoration: underline;
  }

  @keyframes promoDrift {
    0% {
      transform: rotate(-8deg) translateX(0) scale(1.05);
    }
    50% {
      transform: rotate(-8deg) translateX(-20px) scale(1.07);
    }
    100% {
      transform: rotate(-8deg) translateX(0) scale(1.05);
    }
  }

  @keyframes glowFloat1 {
    0% {
      transform: translateY(0) translateX(0);
    }
    50% {
      transform: translateY(12px) translateX(-18px);
    }
    100% {
      transform: translateY(0) translateX(0);
    }
  }

  @keyframes glowFloat2 {
    0% {
      transform: translateY(0) translateX(0);
    }
    50% {
      transform: translateY(-14px) translateX(20px);
    }
    100% {
      transform: translateY(0) translateX(0);
    }
  }

  @media (max-width: 768px) {
    .image-banner {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    .image-banner img {
      height: 200px;
    }

    .intro h1 {
      font-size: 2.5em;
    }

    .gallery-promo {
      padding: 0 1em;
    }

    .gallery-promo-content {
      min-height: 220px;
      padding: 1.5em;
    }

    .gallery-promo-grid {
      grid-template-columns: repeat(2, 1fr);
      font-size: 2.8rem;
    }

    .cta {
      flex-direction: column;
      gap: 1em;
    }
  }
</style>